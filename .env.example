# PLDiagnosis 环境变量配置

# ------------------------------------------------------------------------------
# Flask 服务
# ------------------------------------------------------------------------------
FLASK_PORT=5000
FLASK_DEBUG=false
LOG_LEVEL=INFO

# 前端构建产物目录（Docker 部署时自动设置）
# FRONTEND_DIST=web/dist

# ------------------------------------------------------------------------------
# LLM 配置
# ------------------------------------------------------------------------------
# OpenAI 兼容 API（必填）
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ------------------------------------------------------------------------------
# 意图识别
# ------------------------------------------------------------------------------
INTENT_CONFIDENCE_THRESHOLD=0.7
INTENT_FALLBACK_INTENT=general

# ------------------------------------------------------------------------------
# 诊断配置
# ------------------------------------------------------------------------------
DIAGNOSIS_TOOL_TIMEOUT=30

# ------------------------------------------------------------------------------
# 会话管理
# ------------------------------------------------------------------------------
SESSION_MAX_SESSIONS_PER_USER=20
SESSION_SESSION_TTL_HOURS=48
SESSION_AUTO_CLEANUP=true

# ------------------------------------------------------------------------------
# 工具配置
# ------------------------------------------------------------------------------
TOOLS_CONFIG_DIRECTORY=config/tools
TOOLS_AUTO_LOAD=true
